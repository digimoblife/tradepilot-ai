# TradePilot AI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env or real secrets to version control.
#
# Docker usage:  docker compose --env-file .env up
# Native usage:  source .venv/bin/activate && uvicorn app.main:app --reload

# Application
APP_ENV=development

# PostgreSQL — host differs between native (localhost) and Docker (postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tradepilot
POSTGRES_USER=tradepilot
POSTGRES_PASSWORD=change_me

# Async database URL for application (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://tradepilot:change_me@postgres:5432/tradepilot
# Sync database URL for Alembic migrations (psycopg driver)
DATABASE_SYNC_URL=postgresql+psycopg://tradepilot:change_me@postgres:5432/tradepilot

# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_ECHO=false

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Worker
WORKER_NAME=tradepilot-worker
WORKER_POLL_INTERVAL_SECONDS=5

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Evidence Storage
EVIDENCE_STORAGE_BACKEND=filesystem
EVIDENCE_STORAGE_PATH=/data/evidence

# AI Providers — optional, leave empty for local development
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
PROVIDER_ORDER=gemini
DEEPSEEK_API_KEY=
