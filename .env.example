# TradePilot AI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env or real secrets to version control.

# Application
APP_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tradepilot
POSTGRES_USER=tradepilot
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql://tradepilot:change_me@localhost:5432/tradepilot

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Worker
WORKER_POLL_INTERVAL_SECONDS=5

# Evidence Storage
EVIDENCE_STORAGE_BACKEND=filesystem
EVIDENCE_STORAGE_PATH=./storage/evidence

# AI Providers
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
