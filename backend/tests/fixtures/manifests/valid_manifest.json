      "analysis_types": [],
      "dependencies": [
        "common"
      ],
      "used_by": [
        "initial_analysis",
        "watching_update",
        "open_position_update",
        "partial_exit_review"
      ]
    },
    {
      "name": "trade_state",
      "title": "TradePilot AI Trade State",
      "version": "1.0.0",
      "category": "CANONICAL_STATE",
      "root_schema": true,
      "active": true,
      "file": "trade_state.schema.json",
      "schema_id": "https://schemas.tradepilot.local/production/v1/trade_state.schema.json",
      "description": "Canonical user-confirmed state of one Trade Session, including position, thesis, active plan, performance, and confirmed actions.",
      "analysis_types": [],
      "dependencies": [
        "common"
      ],
      "used_by": [
        "application_backend",
        "context_summary",
        "analysis_context_builder",
        "session_lifecycle"
      ]
    },
    {
      "name": "open_position_update",
      "title": "TradePilot AI Open Position Update",
      "version": "1.0.0",
      "category": "AI_ANALYSIS",
      "root_schema": true,
      "active": true,
      "file": "open_position_update.schema.json",
      "schema_id": "https://schemas.tradepilot.local/production/v1/open_position_update.schema.json",
      "description": "Primary analysis contract for an active swing-trading position, including daily summary, orderbook, position condition, thesis, target realism, stop-loss review, plan, and AI assessment.",
      "analysis_types": [
        "OPEN_POSITION_UPDATE"
      ],
      "valid_session_statuses": [
        "OPEN_POSITION"
      ],
      "resulting_session_statuses": [
        "OPEN_POSITION"
      ],
      "dependencies": [
        "common",
        "market_snapshot",
        "evidence"
      ],
      "used_by": [
        "ai_analysis_worker",
        "trade_session_page",
        "context_summary_builder",
        "position_monitor"
      ],
      "priority": "HIGHEST"
    },
    {
      "name": "closing_analysis",
      "title": "TradePilot AI Closing Analysis",
      "version": "1.0.0",
      "category": "AI_ANALYSIS",
      "root_schema": true,
      "active": true,
      "file": "closing_analysis.schema.json",
      "schema_id": "https://schemas.tradepilot.local/production/v1/closing_analysis.schema.json",
      "description": "Final analysis after the entire position has been closed, including trade result, timeline, thesis review, execution quality, mistakes, and lessons.",
      "analysis_types": [
        "CLOSING_ANALYSIS"
      ],
      "valid_session_statuses": [
        "CLOSED_TAKE_PROFIT",
        "CLOSED_STOP_LOSS",
        "CLOSED_MANUAL",
        "CANCELLED"
      ],
      "resulting_session_statuses": [
        "CLOSED_TAKE_PROFIT",
        "CLOSED_STOP_LOSS",
        "CLOSED_MANUAL",
        "CANCELLED"
      ],
      "dependencies": [
        "common",
        "evidence"
      ],
      "used_by": [
        "ai_analysis_worker",
        "trade_session_page",
        "context_summary_builder",
        "trading_journal",
        "reporting_engine"
      ]
    }
