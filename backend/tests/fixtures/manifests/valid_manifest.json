      "analysis_types": [],
      "dependencies": [],
      "used_by": [
        "market_snapshot",
        "trade_state",
        "evidence",
        "initial_analysis",
        "watching_update",
        "open_position_update",
        "partial_exit_review",
        "closing_analysis",
        "context_summary"
      ]
    },
    {
      "name": "market_snapshot",
