        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },
    "CLOSED_MANUAL": {
      "allowed_analysis_types": [
        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },
    "CANCELLED": {
      "allowed_analysis_types": [
        "CLOSING_ANALYSIS"
      ],
