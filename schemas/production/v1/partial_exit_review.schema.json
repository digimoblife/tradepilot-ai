{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tradepilot.local/production/v1/partial_exit_review.schema.json",
  "title": "TradePilot AI Partial Exit Review",
  "description": "Represents one structured AI review after the user confirms a partial exit, including realized result, remaining position, current market condition, thesis status, remaining target realism, stop-loss review, trading plan, and AI assessment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "update_period",
    "comparison",
    "evidence_summary",
    "market_snapshot",
    "partial_exit_confirmation",
    "result_summary",
    "orderbook_analysis",
    "chart_update",
    "remaining_position_assessment",
    "thesis_assessment",
    "remaining_target_assessment",
    "stop_loss_assessment",
    "trading_plan",
    "ai_assessment",
    "changes_from_previous",
    "warnings_and_missing_information"
  ],
  "properties": {
    "metadata": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/analysisMetadata"
    },

    "update_period": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/updatePeriod"
    },

    "comparison": {
      "$ref": "#/$defs/comparisonSummary"
    },

    "evidence_summary": {
      "$ref": "https://schemas.tradepilot.local/production/v1/evidence.schema.json#/$defs/evidenceSummary"
    },

    "market_snapshot": {
      "$ref": "https://schemas.tradepilot.local/production/v1/market_snapshot.schema.json"
    },

    "partial_exit_confirmation": {
      "$ref": "#/$defs/partialExitConfirmation"
    },

    "result_summary": {
      "$ref": "#/$defs/resultSummary"
    },

    "orderbook_analysis": {
      "$ref": "#/$defs/orderbookAnalysis"
    },

    "chart_update": {
      "$ref": "#/$defs/chartUpdate"
    },

    "remaining_position_assessment": {
      "$ref": "#/$defs/remainingPositionAssessment"
    },

    "thesis_assessment": {
      "$ref": "#/$defs/thesisAssessment"
    },

    "remaining_target_assessment": {
      "$ref": "#/$defs/remainingTargetAssessment"
    },

    "stop_loss_assessment": {
      "$ref": "#/$defs/stopLossAssessment"
    },

    "trading_plan": {
      "$ref": "#/$defs/tradingPlan"
    },

    "ai_assessment": {
      "$ref": "#/$defs/partialExitAiAssessment"
    },

    "changes_from_previous": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/materialChangeArray"
    },

    "warnings_and_missing_information": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/warningsAndMissingInformation"
    }
  },

  "$defs": {
    "comparisonSummary": {
      "title": "Comparison Summary",
      "description": "Identifies the previous accepted Open Position or Partial Exit analysis used for comparison.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_available",
        "previous_analysis_id",
        "previous_analysis_type",
        "previous_analysis_timestamp",
        "previous_update_period",
        "summary"
      ],
      "properties": {
        "comparison_available": {
          "type": "boolean"
        },

        "previous_analysis_id": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableUuid"
        },

        "previous_analysis_type": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "OPEN_POSITION_UPDATE",
                "PARTIAL_EXIT_REVIEW"
              ]
            },
            {
              "type": "null"
            }
          ]
        },

        "previous_analysis_timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableTimestamp"
        },

        "previous_update_period": {
          "oneOf": [
            {
              "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/updatePeriod"
            },
            {
              "type": "null"
            }
          ]
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison_available": {
                "const": false
              }
            },
            "required": [
              "comparison_available"
            ]
          },
          "then": {
            "properties": {
              "previous_analysis_id": {
                "type": "null"
              },
              "previous_analysis_type": {
                "type": "null"
              },
              "previous_analysis_timestamp": {
                "type": "null"
              },
              "previous_update_period": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_available": {
                "const": true
              }
            },
            "required": [
              "comparison_available"
            ]
          },
          "then": {
            "properties": {
              "previous_analysis_id": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/uuid"
              },
              "previous_analysis_type": {
                "type": "string",
                "enum": [
                  "OPEN_POSITION_UPDATE",
                  "PARTIAL_EXIT_REVIEW"
                ]
              },
              "previous_analysis_timestamp": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
              },
              "previous_update_period": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/updatePeriod"
              }
            }
          }
        }
      ]
    },

    "partialExitConfirmation": {
      "title": "Partial Exit Confirmation",
      "description": "User-confirmed details of the partial exit execution.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed",
        "confirmation_action_id",
        "exit_timestamp",
        "exit_price",
        "exited_quantity",
        "remaining_quantity",
        "exit_reason",
        "user_note"
      ],
      "properties": {
        "confirmed": {
          "const": true
        },

        "confirmation_action_id": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/uuid"
        },

        "exit_timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
        },

        "exit_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "exited_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "remaining_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "exit_reason": {
          "type": "string",
          "enum": [
            "PARTIAL_TAKE_PROFIT",
            "RISK_REDUCTION",
            "RESISTANCE_REACHED",
            "MOMENTUM_WEAKENING",
            "USER_DECISION",
            "OTHER"
          ]
        },

        "user_note": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableNarrative"
        }
      }
    },

    "resultSummary": {
      "title": "Partial Exit Result Summary",
      "description": "Summary of the result already realized and its effect on the remaining trade.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_price",
        "partial_exit_price",
        "exited_quantity",
        "remaining_quantity",
        "realized_profit_loss",
        "realized_return_percentage",
        "capital_recovered_percentage",
        "original_risk_reduced",
        "summary"
      ],
      "properties": {
        "entry_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "partial_exit_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "exited_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "remaining_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "realized_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/signedNumber"
        },

        "realized_return_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/percentage"
        },

        "capital_recovered_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "original_risk_reduced": {
          "type": "boolean"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "orderbookAnalysis": {
      "title": "Partial Exit Orderbook Analysis",
      "description": "Latest orderbook analysis used to evaluate the remaining position after a partial exit.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "buyer_strength",
        "seller_pressure",
        "best_bid",
        "best_offer",
        "bid_support",
        "offer_resistance",
        "buyer_observations",
        "seller_observations",
        "important_changes",
        "supports_remaining_position",
        "conclusion",
        "limitations"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },

        "buyer_strength": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/buyerStrength"
        },

        "seller_pressure": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/sellerPressure"
        },

        "best_bid": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "best_offer": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "bid_support": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "offer_resistance": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "buyer_observations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "seller_observations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "important_changes": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "supports_remaining_position": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "conclusion": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "limitations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "available": {
                "const": false
              }
            },
            "required": [
              "available"
            ]
          },
          "then": {
            "properties": {
              "buyer_strength": {
                "const": "UNKNOWN"
              },
              "seller_pressure": {
                "const": "UNKNOWN"
              },
              "best_bid": {
                "type": "null"
              },
              "best_offer": {
                "type": "null"
              },
              "bid_support": {
                "type": "null"
              },
              "offer_resistance": {
                "type": "null"
              },
              "buyer_observations": {
                "maxItems": 0
              },
              "seller_observations": {
                "maxItems": 0
              },
              "important_changes": {
                "maxItems": 0
              },
              "supports_remaining_position": {
                "type": "null"
              },
              "limitations": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },

    "chartUpdate": {
      "title": "Partial Exit Chart Update",
      "description": "Compact chart context for evaluating the remaining position.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "updated_chart_available",
        "using_historical_context",
        "chart_context_timestamp",
        "short_term_trend",
        "medium_term_trend",
        "structure_status",
        "nearest_support",
        "nearest_resistance",
        "breakout_status",
        "breakdown_status",
        "supports_remaining_position",
        "conclusion",
        "limitations"
      ],
      "properties": {
        "updated_chart_available": {
          "type": "boolean"
        },

        "using_historical_context": {
          "type": "boolean"
        },

        "chart_context_timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableTimestamp"
        },

        "short_term_trend": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/trendDirection"
        },

        "medium_term_trend": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/trendDirection"
        },

        "structure_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/structureStatus"
        },

        "nearest_support": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "nearest_resistance": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "breakout_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/breakoutStatus"
        },

        "breakdown_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/breakdownStatus"
        },

        "supports_remaining_position": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "conclusion": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "limitations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "updated_chart_available": {
                "const": false
              },
              "using_historical_context": {
                "const": false
              }
            },
            "required": [
              "updated_chart_available",
              "using_historical_context"
            ]
          },
          "then": {
            "properties": {
              "chart_context_timestamp": {
                "type": "null"
              },
              "short_term_trend": {
                "const": "UNKNOWN"
              },
              "medium_term_trend": {
                "const": "UNKNOWN"
              },
              "structure_status": {
                "const": "UNKNOWN"
              },
              "nearest_support": {
                "type": "null"
              },
              "nearest_resistance": {
                "type": "null"
              },
              "breakout_status": {
                "const": "UNKNOWN"
              },
              "breakdown_status": {
                "const": "UNKNOWN"
              },
              "supports_remaining_position": {
                "type": "null"
              },
              "limitations": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },

    "remainingPositionAssessment": {
      "title": "Remaining Position Assessment",
      "description": "Current condition and performance of the quantity that remains after the partial exit.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_price",
        "current_price",
        "original_quantity",
        "exited_quantity",
        "remaining_quantity",
        "active_stop_loss",
        "active_target",
        "realized_profit_loss",
        "unrealized_profit_loss",
        "unrealized_return_percentage",
        "total_trade_profit_loss",
        "total_trade_return_percentage",
        "distance_to_stop_percentage",
        "distance_to_target_percentage",
        "health",
        "summary"
      ],
      "properties": {
        "entry_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "current_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "original_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "exited_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "remaining_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "active_stop_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "active_target": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "realized_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/signedNumber"
        },

        "unrealized_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableSignedNumber"
        },

        "unrealized_return_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "total_trade_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableSignedNumber"
        },

        "total_trade_return_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "distance_to_stop_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "distance_to_target_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "health": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/positionHealth"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "thesisAssessment": {
      "title": "Partial Exit Thesis Assessment",
      "description": "Evaluation of whether the original thesis remains valid for the remaining quantity.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "remains_valid",
        "summary",
        "strengthening_evidence",
        "weakening_evidence",
        "partial_exit_effect",
        "invalidation_condition",
        "invalidation_price",
        "invalidation_triggered"
      ],
      "properties": {
        "status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/thesisStatus"
        },

        "remains_valid": {
          "type": "boolean"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "strengthening_evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "weakening_evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "partial_exit_effect": {
          "type": "string",
          "enum": [
            "RISK_SIGNIFICANTLY_REDUCED",
            "RISK_REDUCED",
            "NEUTRAL",
            "REMAINING_POSITION_STILL_HIGH_RISK",
            "UNKNOWN"
          ]
        },

        "invalidation_condition": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "invalidation_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "invalidation_triggered": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "INVALIDATED"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "remains_valid": {
                "const": false
              },
              "invalidation_triggered": {
                "const": true
              },
              "weakening_evidence": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },

    "remainingTargetAssessment": {
      "title": "Remaining Target Assessment",
      "description": "Assessment of whether the target for the remaining quantity remains realistic.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_target",
        "still_realistic",
        "realism",
        "target_probability",
        "distance_to_target_percentage",
        "primary_obstacle",
        "required_condition",
        "revised_target_proposed",
        "proposed_target",
        "summary"
      ],
      "properties": {
        "current_target": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "still_realistic": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "realism": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/targetRealism"
        },

        "target_probability": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableProbability"
        },

        "distance_to_target_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "primary_obstacle": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableShortText"
        },

        "required_condition": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableNarrative"
        },

        "revised_target_proposed": {
          "type": "boolean"
        },

        "proposed_target": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "revised_target_proposed": {
                "const": true
              }
            },
            "required": [
              "revised_target_proposed"
            ]
          },
          "then": {
            "properties": {
              "proposed_target": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "revised_target_proposed": {
                "const": false
