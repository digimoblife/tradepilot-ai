{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tradepilot.local/production/v1/open_position_update.schema.json",
  "title": "TradePilot AI Open Position Update",
  "description": "Represents one structured AI analysis update for an active swing-trading position, including today's market summary, orderbook observations, chart context, position condition, thesis validity, target realism, stop-loss review, trading plan, AI assessment, and material changes from the previous update.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "update_period",
    "comparison",
    "evidence_summary",
    "market_snapshot",
    "today_summary",
    "orderbook_analysis",
    "chart_update",
    "position_assessment",
    "thesis_assessment",
    "target_assessment",
    "stop_loss_assessment",
    "trading_plan",
    "ai_assessment",
    "changes_from_previous",
    "warnings_and_missing_information"
  ],
  "properties": {
    "metadata": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/analysisMetadata"
    },

    "update_period": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/updatePeriod"
    },

    "comparison": {
      "$ref": "#/$defs/comparisonSummary"
    },

    "evidence_summary": {
      "$ref": "https://schemas.tradepilot.local/production/v1/evidence.schema.json#/$defs/evidenceSummary"
    },

    "market_snapshot": {
      "$ref": "https://schemas.tradepilot.local/production/v1/market_snapshot.schema.json"
    },

    "today_summary": {
      "$ref": "#/$defs/todaySummary"
    },

    "orderbook_analysis": {
      "$ref": "#/$defs/orderbookAnalysis"
    },

    "chart_update": {
      "$ref": "#/$defs/chartUpdate"
    },

    "position_assessment": {
      "$ref": "#/$defs/positionAssessment"
    },

    "thesis_assessment": {
      "$ref": "#/$defs/thesisAssessment"
    },

    "target_assessment": {
      "$ref": "#/$defs/targetAssessment"
    },

    "stop_loss_assessment": {
      "$ref": "#/$defs/stopLossAssessment"
    },

    "trading_plan": {
      "$ref": "#/$defs/tradingPlan"
    },

    "ai_assessment": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/aiAssessment"
    },

    "changes_from_previous": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/materialChangeArray"
    },

    "warnings_and_missing_information": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/warningsAndMissingInformation"
    }
  },

  "$defs": {
    "comparisonSummary": {
      "title": "Comparison Summary",
      "description": "Identifies the previous accepted analysis used for longitudinal comparison.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_available",
        "previous_analysis_id",
        "previous_analysis_timestamp",
        "previous_update_period",
        "summary"
      ],
      "properties": {
        "comparison_available": {
          "type": "boolean"
        },

        "previous_analysis_id": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableUuid"
        },

        "previous_analysis_timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableTimestamp"
        },

        "previous_update_period": {
          "oneOf": [
            {
              "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/updatePeriod"
            },
            {
              "type": "null"
            }
          ]
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison_available": {
                "const": false
              }
            },
            "required": [
              "comparison_available"
            ]
          },
          "then": {
            "properties": {
              "previous_analysis_id": {
                "type": "null"
              },
              "previous_analysis_timestamp": {
                "type": "null"
              },
              "previous_update_period": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_available": {
                "const": true
              }
            },
            "required": [
              "comparison_available"
            ]
          },
          "then": {
            "properties": {
              "previous_analysis_id": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/uuid"
              },
              "previous_analysis_timestamp": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
              },
              "previous_update_period": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/updatePeriod"
              }
            }
          }
        }
      ]
    },

    "todaySummary": {
      "title": "Today's Summary",
      "description": "User-facing summary of today's price movement and current market condition.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open",
        "high",
        "low",
        "last_or_close",
        "average",
        "change_percentage",
        "position_in_daily_range",
        "summary"
      ],
      "properties": {
        "open": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "high": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "low": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "last_or_close": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "average": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "change_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "position_in_daily_range": {
          "type": "string",
          "enum": [
            "NEAR_LOW",
            "LOWER_HALF",
            "MIDDLE",
            "UPPER_HALF",
            "NEAR_HIGH",
            "UNKNOWN"
          ]
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "orderbookAnalysis": {
      "title": "Orderbook Analysis",
      "description": "Practical interpretation of the latest orderbook screenshot for an active position.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "buyer_strength",
        "seller_pressure",
        "best_bid",
        "best_offer",
        "bid_support",
        "offer_resistance",
        "spread_observation",
        "buyer_observations",
        "seller_observations",
        "important_changes",
        "supports_position",
        "conclusion",
        "limitations"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },

        "buyer_strength": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/buyerStrength"
        },

        "seller_pressure": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/sellerPressure"
        },

        "best_bid": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "best_offer": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "bid_support": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "offer_resistance": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "spread_observation": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableShortText"
        },

        "buyer_observations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "seller_observations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "important_changes": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "supports_position": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "conclusion": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "limitations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "available": {
                "const": false
              }
            },
            "required": [
              "available"
            ]
          },
          "then": {
            "properties": {
              "buyer_strength": {
                "const": "UNKNOWN"
              },
              "seller_pressure": {
                "const": "UNKNOWN"
              },
              "best_bid": {
                "type": "null"
              },
              "best_offer": {
                "type": "null"
              },
              "bid_support": {
                "type": "null"
              },
              "offer_resistance": {
                "type": "null"
              },
              "spread_observation": {
                "type": "null"
              },
              "buyer_observations": {
                "maxItems": 0
              },
              "seller_observations": {
                "maxItems": 0
              },
              "important_changes": {
                "maxItems": 0
              },
              "supports_position": {
                "type": "null"
              },
              "limitations": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "available": {
                "const": true
              }
            },
            "required": [
              "available"
            ]
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "buyer_observations": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "seller_observations": {
                    "minItems": 1
                  }
                }
              }
            ]
          }
        }
      ]
    },

    "chartUpdate": {
      "title": "Chart Update",
      "description": "Compact chart context used during routine Open Position updates.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "updated_chart_available",
        "using_historical_context",
        "chart_context_timestamp",
        "short_term_trend",
        "medium_term_trend",
        "structure_status",
        "nearest_support",
        "nearest_resistance",
        "breakout_status",
        "breakdown_status",
        "supports_position",
        "conclusion",
        "limitations"
      ],
      "properties": {
        "updated_chart_available": {
          "type": "boolean"
        },

        "using_historical_context": {
          "type": "boolean"
        },

        "chart_context_timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableTimestamp"
        },

        "short_term_trend": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/trendDirection"
        },

        "medium_term_trend": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/trendDirection"
        },

        "structure_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/structureStatus"
        },

        "nearest_support": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "nearest_resistance": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePriceLevel"
        },

        "breakout_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/breakoutStatus"
        },

        "breakdown_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/breakdownStatus"
        },

        "supports_position": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "conclusion": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "limitations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "updated_chart_available": {
                "const": false
              },
              "using_historical_context": {
                "const": false
              }
            },
            "required": [
              "updated_chart_available",
              "using_historical_context"
            ]
          },
          "then": {
            "properties": {
              "chart_context_timestamp": {
                "type": "null"
              },
              "short_term_trend": {
                "const": "UNKNOWN"
              },
              "medium_term_trend": {
                "const": "UNKNOWN"
              },
              "structure_status": {
                "const": "UNKNOWN"
              },
              "nearest_support": {
                "type": "null"
              },
              "nearest_resistance": {
                "type": "null"
              },
              "breakout_status": {
                "const": "UNKNOWN"
              },
              "breakdown_status": {
                "const": "UNKNOWN"
              },
              "supports_position": {
                "type": "null"
              },
              "limitations": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "using_historical_context": {
                "const": true
              }
            },
            "required": [
              "using_historical_context"
            ]
          },
          "then": {
            "properties": {
              "chart_context_timestamp": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
              },
              "limitations": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },

    "positionAssessment": {
      "title": "Position Assessment",
      "description": "Current condition and performance of the confirmed active position.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_price",
        "current_price",
        "remaining_quantity",
        "active_stop_loss",
        "active_target",
        "unrealized_profit_loss",
        "unrealized_return_percentage",
        "distance_to_stop_percentage",
        "distance_to_target_percentage",
        "holding_duration_days",
        "health",
        "summary"
      ],
      "properties": {
        "entry_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "current_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "remaining_quantity": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/quantity"
        },

        "active_stop_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "active_target": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "unrealized_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableSignedNumber"
        },

        "unrealized_return_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "distance_to_stop_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "distance_to_target_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "holding_duration_days": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nonNegativeInteger"
        },

        "health": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/positionHealth"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "thesisAssessment": {
      "title": "Thesis Assessment",
      "description": "Current evaluation of whether the original swing-trading thesis remains valid.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "remains_valid",
        "summary",
        "strengthening_evidence",
        "weakening_evidence",
        "invalidation_condition",
        "invalidation_price",
        "invalidation_triggered"
      ],
      "properties": {
        "status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/thesisStatus"
        },

        "remains_valid": {
          "type": "boolean"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "strengthening_evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "weakening_evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "invalidation_condition": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "invalidation_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "invalidation_triggered": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "INVALIDATED"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "remains_valid": {
                "const": false
              },
              "invalidation_triggered": {
                "const": true
              },
              "weakening_evidence": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "remains_valid": {
                "const": true
              }
            },
            "required": [
              "remains_valid"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "enum": [
                  "STRENGTHENING",
                  "INTACT",
                  "INTACT_BUT_WEAKENING",
                  "UNDER_REVIEW"
                ]
              }
            }
          }
        }
      ]
    },

    "targetAssessment": {
      "title": "Target Assessment",
      "description": "Assessment of whether the current take-profit target remains realistic.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_price",
        "still_realistic",
        "realism",
        "target_probability",
        "distance_to_target_percentage",
        "primary_obstacle",
        "required_condition",
        "revised_target_proposed",
        "proposed_target",
        "summary"
      ],
      "properties": {
        "target_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "still_realistic": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "realism": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/targetRealism"
        },

        "target_probability": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableProbability"
        },

        "distance_to_target_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "primary_obstacle": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableShortText"
        },

        "required_condition": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableNarrative"
        },

        "revised_target_proposed": {
          "type": "boolean"
        },

        "proposed_target": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "target_price": {
                "type": "null"
              }
            },
            "required": [
              "target_price"
            ]
          },
          "then": {
            "properties": {
              "still_realistic": {
                "type": "null"
              },
              "realism": {
                "const": "NOT_APPLICABLE"
              },
              "target_probability": {
                "type": "null"
              },
              "distance_to_target_percentage": {
                "type": "null"
              },
              "primary_obstacle": {
                "type": "null"
              },
              "required_condition": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "still_realistic": {
                "const": false
              }
            },
            "required": [
              "still_realistic"
            ]
          },
          "then": {
            "properties": {
              "realism": {
                "enum": [
                  "UNLIKELY",
                  "NO_LONGER_REALISTIC"
                ]
              },
              "primary_obstacle": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "revised_target_proposed": {
                "const": true
              }
            },
            "required": [
              "revised_target_proposed"
            ]
          },
          "then": {
            "properties": {
              "proposed_target": {
                "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "revised_target_proposed": {
                "const": false
              }
            },
            "required": [
              "revised_target_proposed"
            ]
          },
          "then": {
            "properties": {
              "proposed_target": {
                "type": "null"
              }
            }
