  "analysis_type_registry": {
    "INITIAL_ANALYSIS": {
      "schema": "initial_analysis",
      "schema_version": "1.0.0",
      "requires_position": false,
      "requires_user_confirmation_before_execution": true,
      "required_evidence": [
        "ORDERBOOK_SCREENSHOT",
        "CHART_3_MONTH",
        "CHART_6_MONTH"
      ],
      "optional_evidence": [
        "MARKET_SCREENSHOT",
        "USER_NOTE",
        "CHART_OTHER"
      ]
    },

    "WATCHING_UPDATE": {
      "schema": "watching_update",
      "schema_version": "1.0.0",
      "requires_position": false,
      "requires_previous_analysis": true,
      "requires_user_confirmation_before_execution": true,
      "required_evidence": [
        "ORDERBOOK_SCREENSHOT"
      ],
      "optional_evidence": [
        "CHART_3_MONTH",
        "CHART_6_MONTH",
        "CHART_OTHER",
        "MARKET_SCREENSHOT",
        "USER_NOTE"
      ]
    },

    "OPEN_POSITION_UPDATE": {
      "schema": "open_position_update",
      "schema_version": "1.0.0",
      "requires_position": true,
      "requires_previous_analysis": false,
      "requires_canonical_trade_state": true,
      "requires_user_confirmation_before_state_change": true,
      "required_evidence": [
        "ORDERBOOK_SCREENSHOT"
      ],
      "optional_evidence": [
        "CHART_3_MONTH",
        "CHART_6_MONTH",
        "CHART_OTHER",
        "MARKET_SCREENSHOT",
        "USER_NOTE"
      ]
    },

    "PARTIAL_EXIT_REVIEW": {
      "schema": "partial_exit_review",
      "schema_version": "1.0.0",
      "requires_position": true,
      "requires_partial_position": true,
      "requires_canonical_trade_state": true,
      "requires_user_confirmation_before_state_change": true,
      "required_evidence": [
        "PARTIAL_EXIT_CONFIRMATION"
      ],
      "optional_evidence": [
        "ORDERBOOK_SCREENSHOT",
        "CHART_3_MONTH",
        "CHART_6_MONTH",
        "CHART_OTHER",
        "MARKET_SCREENSHOT",
        "USER_NOTE"
      ]
    },

    "CLOSING_ANALYSIS": {
      "schema": "closing_analysis",
      "schema_version": "1.0.0",
      "requires_position": true,
      "requires_closed_position": true,
      "requires_canonical_trade_state": true,
      "required_evidence": [
        "EXIT_CONFIRMATION"
      ],
      "optional_evidence": [
        "ORDERBOOK_SCREENSHOT",
        "CHART_3_MONTH",
        "CHART_6_MONTH",
        "CHART_OTHER",
        "MARKET_SCREENSHOT",
        "USER_NOTE",
        "PARTIAL_EXIT_CONFIRMATION"
      ]
    }
  },

  "session_status_schema_mapping": {
    "DRAFT": {
      "allowed_analysis_types": [],
      "canonical_schema": "trade_state"
    },

    "READY_FOR_ANALYSIS": {
      "allowed_analysis_types": [
        "INITIAL_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },

    "ANALYZING": {
      "allowed_analysis_types": [
        "INITIAL_ANALYSIS",
        "WATCHING_UPDATE",
        "OPEN_POSITION_UPDATE",
        "PARTIAL_EXIT_REVIEW",
        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },

    "WATCHING": {
      "allowed_analysis_types": [
        "WATCHING_UPDATE"
      ],
      "canonical_schema": "trade_state"
    },

    "OPEN_POSITION": {
      "allowed_analysis_types": [
        "OPEN_POSITION_UPDATE"
      ],
      "canonical_schema": "trade_state"
    },

    "PARTIALLY_CLOSED": {
      "allowed_analysis_types": [
        "OPEN_POSITION_UPDATE",
        "PARTIAL_EXIT_REVIEW"
      ],
      "canonical_schema": "trade_state"
    },

    "CLOSED_TAKE_PROFIT": {
      "allowed_analysis_types": [
        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },

    "CLOSED_STOP_LOSS": {
      "allowed_analysis_types": [
        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },

    "CLOSED_MANUAL": {
      "allowed_analysis_types": [
        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },

    "CANCELLED": {
      "allowed_analysis_types": [
        "CLOSING_ANALYSIS"
      ],
      "canonical_schema": "trade_state"
    },

    "ARCHIVED": {
      "allowed_analysis_types": [],
      "canonical_schema": "trade_state"
    }
  },

  "validation": {
    "json_schema_validation_required": true,
    "domain_validation_required": true,
    "validate_format_keywords": true,
    "reject_unknown_properties": true,
    "reject_unknown_schema_versions": true,
    "reject_inactive_schemas": true,
    "reject_unregistered_schema_ids": true,

    "domain_validators": [
      "validate_market_snapshot",
      "validate_trade_state",
      "validate_position_calculations",
      "validate_price_level_relationships",
      "validate_entry_plan",
      "validate_stop_loss_plan",
      "validate_target_plan",
      "validate_analysis_trade_state_consistency",
      "validate_session_status_transition",
      "validate_user_confirmation_requirement",
      "validate_partial_exit",
      "validate_closing_result",
      "validate_trade_timeline",
      "validate_context_summary",
      "validate_context_cutoff",
      "validate_provider_output"
    ]
  },

  "canonical_state_rules": {
    "canonical_schema": "trade_state",
    "ai_may_directly_modify_canonical_state": false,

    "user_confirmation_required_for": [
      "POSITION_OPENED",
      "POSITION_DETAILS_CORRECTED",
      "STOP_LOSS_CONFIRMED",
      "STOP_LOSS_CHANGED",
      "TARGET_CONFIRMED",
      "TARGET_CHANGED",
      "PARTIAL_EXIT_CONFIRMED",
      "FULL_EXIT_CONFIRMED",
      "SESSION_CANCELLED"
    ],

    "ai_proposals_are_non_canonical_until_confirmed": true,

    "unknown_numeric_values_must_use_null": true,
    "unknown_numeric_values_must_not_use_zero": true
  },

  "context_rules": {
    "context_schema": "context_summary",
    "context_is_canonical_state": false,
    "context_must_include_latest_trade_state": true,
    "context_must_include_latest_accepted_analysis": true,
    "context_must_preserve_user_confirmed_actions": true,
    "context_must_label_historical_chart_usage": true,
    "context_must_preserve_pending_confirmations": true,
    "context_must_not_include_events_after_source_cutoff": true
  },

  "narrative_rules": {
    "user_facing_language": "id",
    "technical_keys_language": "en",
    "enum_language": "en",
    "facts_and_interpretations_should_be_distinguishable": true,
    "probabilities_are_estimates_not_guarantees": true,
    "confidence_is_not_probability": true
  },

  "storage_rules": {
    "store_schema_name": true,
    "store_schema_version": true,
    "store_prompt_version": true,
    "store_provider": true,
    "store_model": true,
    "store_analysis_timestamp": true,
    "store_raw_provider_response": true,
    "store_validated_payload": true,
    "store_validation_errors": true
  },

  "migration_rules": {
    "semantic_versioning": true,
    "allow_patch_upgrade_without_data_migration": true,
    "allow_minor_upgrade_when_backward_compatible": true,
    "require_migration_for_major_upgrade": true,
    "retain_previous_schema_versions": true,
    "never_reinterpret_historical_payload_with_new_schema_without_migration": true
  },

  "experimental_schemas": {
    "enabled": false,
    "directory": "../../experimental/enterprise-draft/",
    "included_in_production_registry": false
  }
}