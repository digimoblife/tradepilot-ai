{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tradepilot.local/production/v1/closing_analysis.schema.json",
  "title": "TradePilot AI Closing Analysis",
  "description": "Represents the final structured analysis after a Trade Session is fully closed, including confirmed exit details, realized result, thesis evaluation, trading-plan execution, timeline review, strengths, mistakes, lessons learned, and final journal summary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "evidence_summary",
    "closing_confirmation",
    "trade_result",
    "trade_timeline",
    "final_thesis_evaluation",
    "plan_execution_evaluation",
    "risk_management_evaluation",
    "what_worked",
    "what_did_not_work",
    "avoidable_mistakes",
    "lessons_learned",
    "future_improvements",
    "final_ai_evaluation",
    "journal_summary",
    "warnings_and_missing_information"
  ],
  "properties": {
    "metadata": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/analysisMetadata"
    },

    "evidence_summary": {
      "$ref": "https://schemas.tradepilot.local/production/v1/evidence.schema.json#/$defs/evidenceSummary"
    },

    "closing_confirmation": {
      "$ref": "#/$defs/closingConfirmation"
    },

    "trade_result": {
      "$ref": "#/$defs/tradeResult"
    },

    "trade_timeline": {
      "$ref": "#/$defs/tradeTimeline"
    },

    "final_thesis_evaluation": {
      "$ref": "#/$defs/finalThesisEvaluation"
    },

    "plan_execution_evaluation": {
      "$ref": "#/$defs/planExecutionEvaluation"
    },

    "risk_management_evaluation": {
      "$ref": "#/$defs/riskManagementEvaluation"
    },

    "what_worked": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
    },

    "what_did_not_work": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
    },

    "avoidable_mistakes": {
      "$ref": "#/$defs/mistakeArray"
    },

    "lessons_learned": {
      "$ref": "#/$defs/lessonArray"
    },

    "future_improvements": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
    },

    "final_ai_evaluation": {
      "$ref": "#/$defs/finalAiEvaluation"
    },

    "journal_summary": {
      "$ref": "#/$defs/journalSummary"
    },

    "warnings_and_missing_information": {
      "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/warningsAndMissingInformation"
    }
  },

  "$defs": {
    "closingConfirmation": {
      "title": "Closing Confirmation",
      "description": "User-confirmed details of the execution that fully closed the remaining position.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed",
        "confirmation_action_id",
        "closing_reason",
        "exit_timestamp",
        "final_exit_price",
        "final_exit_quantity",
        "average_exit_price",
        "user_note"
      ],
      "properties": {
        "confirmed": {
          "const": true
        },

        "confirmation_action_id": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/uuid"
        },

        "closing_reason": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/closingReason"
        },

        "exit_timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
        },

        "final_exit_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "final_exit_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "average_exit_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "user_note": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableNarrative"
        }
      }
    },

    "tradeOutcome": {
      "title": "Trade Outcome",
      "type": "string",
      "enum": [
        "LARGE_PROFIT",
        "PROFIT",
        "SMALL_PROFIT",
        "BREAK_EVEN",
        "SMALL_LOSS",
        "LOSS",
        "LARGE_LOSS"
      ]
    },

    "tradeResult": {
      "title": "Trade Result",
      "description": "Calculated final result of the fully closed Trade Session.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "entry_price",
        "original_quantity",
        "average_exit_price",
        "gross_profit_loss",
        "fees",
        "taxes",
        "net_profit_loss",
        "gross_return_percentage",
        "net_return_percentage",
        "maximum_unrealized_profit_percentage",
        "maximum_unrealized_loss_percentage",
        "holding_duration_calendar_days",
        "holding_duration_trading_days",
        "partial_exit_count",
        "outcome",
        "summary"
      ],
      "properties": {
        "currency": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/currencyCode"
        },

        "entry_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "original_quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },

        "average_exit_price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/price"
        },

        "gross_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/signedNumber"
        },

        "fees": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableNonNegativeNumber"
        },

        "taxes": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableNonNegativeNumber"
        },

        "net_profit_loss": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableSignedNumber"
        },

        "gross_return_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/percentage"
        },

        "net_return_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "maximum_unrealized_profit_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "maximum_unrealized_loss_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "holding_duration_calendar_days": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nonNegativeInteger"
        },

        "holding_duration_trading_days": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nonNegativeInteger"
        },

        "partial_exit_count": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nonNegativeInteger"
        },

        "outcome": {
          "$ref": "#/$defs/tradeOutcome"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "timelineEventType": {
      "title": "Timeline Event Type",
      "type": "string",
      "enum": [
        "SESSION_CREATED",
        "INITIAL_ANALYSIS",
        "WATCHING_UPDATE",
        "POSITION_OPENED",
        "OPEN_POSITION_UPDATE",
        "STOP_LOSS_CHANGED",
        "TARGET_CHANGED",
        "PARTIAL_EXIT",
        "FINAL_EXIT",
        "THESIS_STRENGTHENED",
        "THESIS_WEAKENED",
        "THESIS_INVALIDATED",
        "OTHER"
      ]
    },

    "timelineEvent": {
      "title": "Trade Timeline Event",
      "description": "One important event in the Trade Session journey.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "event_type",
        "price",
        "quantity",
        "related_analysis_id",
        "summary"
      ],
      "properties": {
        "timestamp": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
        },

        "event_type": {
          "$ref": "#/$defs/timelineEventType"
        },

        "price": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePrice"
        },

        "quantity": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableQuantity"
        },

        "related_analysis_id": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableUuid"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        }
      }
    },

    "timelineEventArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timelineEvent"
      },
      "minItems": 2,
      "maxItems": 100
    },

    "tradeTimeline": {
      "title": "Trade Timeline",
      "description": "Compact chronological reconstruction of the Trade Session.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_started_at",
        "position_opened_at",
        "position_closed_at",
        "analysis_count",
        "events",
        "journey_summary"
      ],
      "properties": {
        "session_started_at": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
        },

        "position_opened_at": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
        },

        "position_closed_at": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/timestamp"
        },

        "analysis_count": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/positiveInteger"
        },

        "events": {
          "$ref": "#/$defs/timelineEventArray"
        },

        "journey_summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "thesisOutcome": {
      "title": "Thesis Outcome",
      "type": "string",
      "enum": [
        "FULLY_CONFIRMED",
        "PARTIALLY_CONFIRMED",
        "CORRECT_BUT_POORLY_EXECUTED",
        "INVALIDATED_AFTER_PROGRESS",
        "INVALIDATED_EARLY",
        "INCORRECT",
        "INCONCLUSIVE"
      ]
    },

    "finalThesisEvaluation": {
      "title": "Final Thesis Evaluation",
      "description": "Evaluation of the original trading thesis against the actual trade journey and result.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_thesis",
        "final_thesis_status",
        "outcome",
        "thesis_was_correct",
        "entry_reason_remained_valid",
        "invalidation_condition_respected",
        "supporting_evidence",
        "contradicting_evidence",
        "summary"
      ],
      "properties": {
        "original_thesis": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "final_thesis_status": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/thesisStatus"
        },

        "outcome": {
          "$ref": "#/$defs/thesisOutcome"
        },

        "thesis_was_correct": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "entry_reason_remained_valid": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "invalidation_condition_respected": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "supporting_evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "contradicting_evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "executionQuality": {
      "title": "Execution Quality",
      "type": "string",
      "enum": [
        "EXCELLENT",
        "GOOD",
        "FAIR",
        "POOR",
        "VERY_POOR",
        "NOT_APPLICABLE",
        "UNKNOWN"
      ]
    },

    "planExecutionEvaluation": {
      "title": "Plan Execution Evaluation",
      "description": "Evaluation of how consistently the user followed the accepted entry, hold, target, and exit plan.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_quality",
        "entry_quality",
        "position_management_quality",
        "exit_quality",
        "entry_plan_followed",
        "stop_loss_plan_followed",
        "target_plan_followed",
        "exit_plan_followed",
        "positive_execution_points",
        "execution_deviations",
        "summary"
      ],
      "properties": {
        "overall_quality": {
          "$ref": "#/$defs/executionQuality"
        },

        "entry_quality": {
          "$ref": "#/$defs/executionQuality"
        },

        "position_management_quality": {
          "$ref": "#/$defs/executionQuality"
        },

        "exit_quality": {
          "$ref": "#/$defs/executionQuality"
        },

        "entry_plan_followed": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "stop_loss_plan_followed": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "target_plan_followed": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "exit_plan_followed": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "positive_execution_points": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "execution_deviations": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "riskManagementEvaluation": {
      "title": "Risk Management Evaluation",
      "description": "Evaluation of stop-loss discipline, position exposure, profit protection, and risk control throughout the trade.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality",
        "initial_risk_percentage",
        "maximum_loss_limit_respected",
        "stop_loss_used",
        "stop_loss_respected",
        "profit_protected",
        "partial_exit_used",
        "risk_increased_without_confirmation",
        "strengths",
        "weaknesses",
        "summary"
      ],
      "properties": {
        "quality": {
          "$ref": "#/$defs/executionQuality"
        },

        "initial_risk_percentage": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullablePercentage"
        },

        "maximum_loss_limit_respected": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "stop_loss_used": {
          "type": "boolean"
        },

        "stop_loss_respected": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "profit_protected": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "partial_exit_used": {
          "type": "boolean"
        },

        "risk_increased_without_confirmation": {
          "type": "boolean"
        },

        "strengths": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "weaknesses": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortTextArray"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "mistakeCategory": {
      "title": "Mistake Category",
      "type": "string",
      "enum": [
        "ENTRY",
        "POSITION_SIZE",
        "STOP_LOSS",
        "TARGET",
        "ORDERBOOK_READING",
        "CHART_READING",
        "THESIS",
        "RISK_MANAGEMENT",
        "EXIT",
        "DISCIPLINE",
        "TIMING",
        "EMOTIONAL_DECISION",
        "DATA_QUALITY",
        "OTHER"
      ]
    },

    "mistakeSeverity": {
      "title": "Mistake Severity",
      "type": "string",
      "enum": [
        "MINOR",
        "MATERIAL",
        "MAJOR"
      ]
    },

    "mistake": {
      "title": "Avoidable Mistake",
      "description": "One avoidable mistake identified from the Trade Session.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "severity",
        "description",
        "impact",
        "how_to_avoid"
      ],
      "properties": {
        "category": {
          "$ref": "#/$defs/mistakeCategory"
        },

        "severity": {
          "$ref": "#/$defs/mistakeSeverity"
        },

        "description": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        },

        "impact": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        },

        "how_to_avoid": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        }
      }
    },

    "mistakeArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mistake"
      },
      "maxItems": 15,
      "default": []
    },

    "lessonCategory": {
      "title": "Lesson Category",
      "type": "string",
      "enum": [
        "SETUP_SELECTION",
        "ENTRY",
        "ORDERBOOK",
        "CHART",
        "THESIS",
        "STOP_LOSS",
        "TARGET",
        "POSITION_MANAGEMENT",
        "EXIT",
        "DISCIPLINE",
        "RISK_MANAGEMENT",
        "PROCESS",
        "OTHER"
      ]
    },

    "lesson": {
      "title": "Trade Lesson",
      "description": "One reusable lesson learned from the completed Trade Session.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "lesson",
        "evidence",
        "future_rule"
      ],
      "properties": {
        "category": {
          "$ref": "#/$defs/lessonCategory"
        },

        "lesson": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        },

        "evidence": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        },

        "future_rule": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        }
      }
    },

    "lessonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lesson"
      },
      "minItems": 1,
      "maxItems": 15
    },

    "finalTradeGrade": {
      "title": "Final Trade Grade",
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D",
        "E"
      ]
    },

    "finalAiEvaluation": {
      "title": "Final AI Evaluation",
      "description": "Final assessment of the completed trade as a decision-making process, separate from profit or loss alone.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trade_grade",
        "process_score",
        "thesis_score",
        "execution_score",
        "risk_management_score",
        "result_score",
        "good_trade",
        "result_aligned_with_process",
        "summary"
      ],
      "properties": {
        "trade_grade": {
          "$ref": "#/$defs/finalTradeGrade"
        },

        "process_score": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/confidenceScore"
        },

        "thesis_score": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/confidenceScore"
        },

        "execution_score": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/confidenceScore"
        },

        "risk_management_score": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/confidenceScore"
        },

        "result_score": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/confidenceScore"
        },

        "good_trade": {
          "type": "boolean"
        },

        "result_aligned_with_process": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/nullableBoolean"
        },

        "summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        }
      }
    },

    "journalSummary": {
      "title": "Trade Journal Summary",
      "description": "Final compact journal entry that can be displayed in the session and reused in performance reporting.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "setup_summary",
        "entry_summary",
        "management_summary",
        "exit_summary",
        "result_summary",
        "main_lesson",
        "one_sentence_review",
        "tags"
      ],
      "properties": {
        "title": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/shortText"
        },

        "setup_summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "entry_summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "management_summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "exit_summary": {
          "$ref": "https://schemas.tradepilot.local/production/v1/common.schema.json#/$defs/narrative"
        },

        "result_summary": {
